{
  "name": "chuan-website",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run generate-sitemap && run-p type-check \"build-only {@}\" --",
    "deploy": "vite build",
    "preview": "vite preview",
    "test:unit": "vitest",
    "test:e2e": "playwright test",
    "build-only": "vite build",
    "type-check": "vue-tsc --build",
    "lint:oxlint": "oxlint . --fix -D correctness --ignore-path .gitignore",
    "lint:eslint": "eslint . --fix",
    "lint": "run-s lint:*",
    "format": "prettier --write src/",
    "generate-sitemap": "node sitemap-generator.js"
  },
  "dependencies": {
    "@heroicons/vue": "^2.2.0",
    "@types/swiper": "^5.4.3",
    "@unhead/dom": "^2.0.10",
    "@unhead/vue": "^2.0.10",
    "@vueuse/core": "^13.3.0",
    "aos": "^2.3.4",
    "bootstrap-icons": "^1.13.1",
    "lodash.merge": "^4.6.2",
    "pinia": "^3.0.1",
    "sitemap": "^8.0.0",
    "swiper": "^11.2.8",
    "unhead": "^2.0.10",
    "vue": "^3.5.13",
    "vue-gtag": "^3.5.1",
    "vue-i18n": "^11.1.5",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@headlessui/vue": "^1.7.23",
    "@playwright/test": "^1.51.1",
    "@tailwindcss/vite": "^4.1.10",
    "@tsconfig/node22": "^22.0.1",
    "@types/aos": "^3.0.7",
    "@types/jsdom": "^21.1.7",
    "@types/node": "^22.14.0",
    "@vitejs/plugin-vue": "^5.2.3",
    "@vitejs/plugin-vue-jsx": "^4.1.2",
    "@vitest/eslint-plugin": "^1.1.39",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.5.0",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.7.0",
    "eslint": "^9.22.0",
    "eslint-plugin-oxlint": "^0.16.0",
    "eslint-plugin-playwright": "^2.2.0",
    "eslint-plugin-vue": "~10.0.0",
    "gh-pages": "^6.3.0",
    "jiti": "^2.4.2",
    "jsdom": "^26.0.0",
    "npm-run-all2": "^7.0.2",
    "oxlint": "^0.16.0",
    "prettier": "3.5.3",
    "tailwindcss": "^4.1.10",
    "typescript": "~5.8.0",
    "vite": "^6.2.4",
    "vite-plugin-pages": "^0.33.0",
    "vite-plugin-vue-devtools": "^7.7.2",
    "vitest": "^3.1.1",
    "vue-tsc": "^2.2.8"
  }
}
